                      "type": "frame",
                      "id": "RQ07W",
                      "name": "note",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        {
                          "type": "text",
                          "id": "rYTLK",
                          "name": "label",
                          "fill": "$--text-primary",
                          "content": "Collapsed & mobile",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "V97EuL",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Collapsed: the 187 summary gains a read-only ms token (Layers · <layer> · Frame n/N · 250 ms); editing only when expanded. Mobile: ruler + corner grow to >=48px for a comfortable touch target (also enlarging frame ordinals); fps dropped. Pairs with the TimelinePanel mobile touch-targets backlog.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "sA4Do",
                      "name": "note",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        {
                          "type": "text",
                          "id": "x4ZSj",
                          "name": "label",
                          "fill": "$--text-primary",
                          "content": "Tokens (no new tokens)",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "evQXy",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "--ds-* only. Input border --border; focus border --accent; corner surface --bg-elevated; field surface --bg-base; clamp hint --warning; label --text-secondary / value --text-primary / fps --text-tertiary. Light + Dark resolve via theme.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
