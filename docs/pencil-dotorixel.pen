                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        {
                          "type": "text",
                          "id": "m7wbS",
                          "name": "label",
                          "fill": "$--text-primary",
                          "content": "Control & commit",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "Z86pQ",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "A plain numeric input (ms). Commits on Enter or blur, so one user-level retime = one undo step (PRD US16 - coalescing falls out naturally). Steppers and drag-scrub are deferred, not built now.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "M14Gzh",
                      "name": "note",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        {
                          "type": "text",
                          "id": "g0010j",
                          "name": "label",
                          "fill": "$--text-primary",
                          "content": "Clamp & invalid",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "A5Gfv",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Range 1-60000 ms. Out-of-range entries snap to the nearest bound on commit (clamping is a boundary concern in the WASM / journal layer, not the core). Empty or invalid input reverts to the prior value; re-setting the same value is a no-op (no history).",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
