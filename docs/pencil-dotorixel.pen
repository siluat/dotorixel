                      "type": "frame",
                      "id": "FBPxw",
                      "name": "note",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        {
                          "type": "text",
                          "id": "GLbnh",
                          "name": "label",
                          "fill": "$--text-primary",
                          "content": "Scope & implementation",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "600"
                        },
                        {
                          "type": "text",
                          "id": "u9lmJ",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "NOT the reserved transport strip (global play / FPS / loop is a separate M4 item) and no playback. TimelinePanel stays a pure view: the active FrameColumn gains durationMs + a new onSetFrameDuration(frameId, durationMs) callback (mirrors onReorderFrame). New i18n keys (en/ko/ja) for label + aria; fps is decorative (aria-hidden).",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
