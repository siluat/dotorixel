                          "type": "text",
                          "id": "JjdjJ",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Milliseconds is the source of truth. fps is a read-only derived helper (1000 / ms) shown faintly beside the value on desktop; it is never editable and is dropped on mobile to fit the 140px sidebar.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
                          "fontSize": 13,
