                          "type": "text",
                          "id": "KNxob",
                          "name": "body",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Active-frame-only editor in the top-left corner, aligned with the ruler (reuses the previously-empty corner). Edits whichever frame is selected via the ruler - click a frame, edit its duration. No per-cell ms captions; the ruler stays ordinal-only.",
                          "lineHeight": 1.5,
                          "fontFamily": "Inter",
