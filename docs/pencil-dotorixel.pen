                    {
                      "type": "text",
                      "id": "BTFVY",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "--ds-onion-prev #E5484D / --ds-onion-next #3B82F6 — new pair approved in the grill; mirrored here as $--onion-prev / $--onion-next. Single values: ghosts render on the theme-independent canvas checkerboard. The web shell sources its canvas tint constants from these tokens.",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "e1DqNC",
                  "name": "li",
                  "width": "fill_container",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "QW25X",
                      "name": "k",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": 120,
                      "content": "Recipe (pinned)",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "d4DUu",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "ghost = composite_at(neighbor) → ~60% blend toward the tint token → ~40% ghost alpha, nearest-neighbor blit. Drawn between the Reference underlay and the Active composite, farthest first. v1 range fixed at ±1 (config parameterized internally).",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "G8FTQ1",
                  "name": "li",
                  "width": "fill_container",
                  "gap": 12,
                  "children": [
                    {
                      "type": "text",
                      "id": "rCPWg",
                      "name": "k",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": 120,
                      "content": "Toggle",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "b11uJ",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "lucide ghost glyph, third control in the left cluster [Play · Loop · Ghost]. On-state mirrors Loop: accent-subtle fill + 1px accent outline + accent-text glyph (2-channel, color-blind safe), aria-pressed. Disabled at a single frame; ≥44px targets on mobile.",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "mYBkO",
                  "name": "li",
