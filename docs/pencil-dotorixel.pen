                      "name": "k",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": 200,
                      "content": "Two channels, never merged",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "pWvLz",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "the ▾ playhead (transient) and the Active-Frame highlight (top-bar + accent-subtle, the edit pointer) are separate visual channels. The marker may pass over the active cell; neither overrides the other.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "a1CaJF",
                  "name": "note",
                  "width": "fill_container",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "kRzJu",
                      "name": "k",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": 200,
                      "content": "Playback is read-only",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "UtT3l",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "pressing Play never mutates the document, the Active Frame, history, or the dirty flag. Stop returns to the Active Frame you were editing.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "y16VHP",
                  "name": "note",
                  "width": "fill_container",
                  "gap": 14,
                  "children": [
                    {
                      "type": "text",
                      "id": "jE5uY",
                      "name": "k",
                      "fill": "$--text-primary",
                      "textGrowth": "fixed-width",
                      "width": 200,
                      "content": "No global fps",
                      "lineHeight": 1.4,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "OekBl",
                      "name": "v",
                      "fill": "$--text-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "per-frame ms is the source of truth (PRD 193). The bar shows position (n/N), not a global speed; the duration corner already surfaces a derived fps.",
                      "lineHeight": 1.5,
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
